# contextlake knowledge-layer config (example).
#
# Copy to ~/.contextlake/kb.toml (or pass with --config) and fill in your own
# values. Everything here is organization-specific — keep your real copy OUT of
# version control. All values below are PLACEHOLDERS.

[kb]
store_dir = "~/.contextlake/kb"
# Languages to parse (a pluggable parser registry backs these).
languages = ["csharp", "typescript", "python"]
# Indexing scope & speed (all optional — sensible defaults shown):
# Skip machine-generated/derived files (*.designer.cs, *.min.js, AssemblyInfo.cs,
# @generated/<auto-generated> headers) — graph noise derived from real sources.
# The sources they derive from are still indexed, so nothing is lost. Set false to index them.
# skip_generated = true
# Skip code files larger than this many bytes (data blobs / vendored bundles). Raise to index them.
# max_file_bytes = 5000000
# Parallel worker processes for the per-repo parse (CPU-bound). Omit/leave unset for
# auto (cpu_count - 1, capped at 8); set 1 to force serial. Persist stays single-process.
# index_workers = 8

[embeddings]
# Semantic/NL search tier. Off by default; when enabled, run `contextlake embed`
# to vectorize indexed nodes and `serve` then exposes a `semantic_search` tool.
enabled = false
# Provider: "auto" (default) | "builtin" | "ollama" | "openai".
#   auto    -> a reachable local Ollama, else the built-in CPU embedder (if its
#              extra is installed), else skip. Zero-config: works the moment you
#              flip enabled=true (no daemon, no API key).
#   builtin -> always the in-process CPU embedder (see engine below).
provider = "auto"
batch_size = 64
# Built-in CPU embedder (no Ollama / API key). The model auto-downloads once to
# `cache_dir` on first `embed`. Two engines:
#   engine = "model2vec"  -> static potion-base-8M (~30MB, MIT), numpy, very fast.
#                            Install: pip install "contextlake[kb-local]"
#   engine = "fastembed"  -> ONNX bge-small (~90MB, MIT), higher quality, heavier.
#                            Install: pip install "contextlake[kb-fastembed]"
# engine = "model2vec"
# model = "minishlab/potion-base-8M"     # override the default model id if you like
# cache_dir = "~/.contextlake/models"    # where downloaded models live
#
# For a local Ollama daemon instead:
#   provider = "ollama"
#   model = "nomic-embed-text"
#   base_url = "http://127.0.0.1:11434"
# For an OpenAI-compatible API (hosted, or a local server like LM Studio / Jan /
# llama.cpp / vLLM) instead:
#   provider = "openai"
#   model = "text-embedding-3-small"
#   base_url = "https://api.openai.com/v1"     # or e.g. http://127.0.0.1:1234/v1
#   api_key_env = "OPENAI_API_KEY"             # env var with the key; never the key itself
#
# Behind a TLS-inspecting corporate proxy, the first model download needs your OS
# CA bundle: export REQUESTS_CA_BUNDLE / SSL_CERT_FILE to it (see docs/releasing.md).
# Do NOT switch the embedder model/dimension against an existing store without
# re-embedding from scratch (delete the store's embeddings.sqlite) — a guard errors.
#
# Vector backend: "auto" uses the sqlite-vec ANN index when installed
# (pip install "contextlake[kb-vec]"), else an exact pure-Python cosine scan.
# Force with "sqlite-vec" or "brute".
vector_backend = "auto"

[llm]
# LLM tier for `contextlake wiki` (curated pages + a verification council).
# Off by default. Provider: "auto" (default) | "builtin" | "ollama" | "openai".
#   auto    -> reachable local Ollama, else the built-in CPU LLM (if installed), else skip.
#   builtin -> in-process small GGUF via llama-cpp-python.
enabled = false
provider = "auto"
council_size = 3        # reviewer lenses (accuracy / completeness / clarity)
accept_score = 0.7      # mean council score required to publish a page
# Built-in CPU LLM (no Ollama / API key): a small Qwen2.5-0.5B-Instruct GGUF
# (Apache-2.0), auto-downloaded once to cache_dir. CPU generation is SLOW and the
# wiki makes ~4 calls/repo, so this suits small workspaces — prefer Ollama / an API
# / the Docker image at scale. Install: pip install "contextlake[llm-local]"
# provider = "builtin"
# model = "Qwen/Qwen2.5-0.5B-Instruct-GGUF"       # GGUF repo id
# model_file = "qwen2.5-0.5b-instruct-q4_k_m.gguf" # specific quant
# cache_dir = "~/.contextlake/models"
#
# For a local Ollama daemon instead:
#   provider = "ollama"
#   model = "llama3.1"
#   base_url = "http://127.0.0.1:11434"
# For an OpenAI-compatible chat API (hosted, or a local server) instead:
#   provider = "openai"
#   model = "gpt-4o-mini"
#   base_url = "https://api.openai.com/v1"     # or your local server's /v1
#   api_key_env = "OPENAI_API_KEY"             # env var with the key; never the key itself

# --- Knowledge-source connectors (0..N) -------------------------------------
# `contextlake connect` runs these after indexing to link repos to external
# knowledge. Each Atlassian org is its own connector with its own auth session;
# set a distinct `auth_dir` per org so their OAuth caches never collide.
[[sources]]
type = "atlassian"
name = "primary"
mcp = "https://mcp.atlassian.com/v1/mcp/authv2"
# auth_dir = "~/.contextlake/auth/primary"   # isolated mcp-remote OAuth cache
# timeout = 120                              # seconds per MCP call

[[sources]]
type = "atlassian"
name = "secondary"
mcp = "https://mcp.atlassian.com/v1/mcp/authv2"
# auth_dir = "~/.contextlake/auth/secondary"

# The Figma connector links repos to the design files their docs reference. The
# file name comes from the URL itself; a configured Figma MCP is optional and only
# used to verify reachability. Point it at the Figma desktop "Dev Mode MCP server"
# (enable it in Figma > Preferences) via mcp, or at any MCP stdio command.
# GitLab itself as a knowledge source: links each repo to its open merge requests
# and issues (read via your authenticated `glab`). Needs no association rules.
[[sources]]
type = "gitlab"
name = "gitlab"
# group = "your-gitlab-group"   # prefixed to each repo's path to form the project
# per_page = 50

[[sources]]
type = "figma"
name = "design"
# mcp = "http://127.0.0.1:3845/mcp"   # Figma desktop Dev Mode MCP (bridged via mcp-remote)
# mcp_command = "figma-mcp --stdio"   # or a local stdio MCP command
# NOTE (WSL2): the desktop server listens on the Windows host's 127.0.0.1; reach it
# from WSL only with mirrored networking (.wslconfig networkingMode=mirrored) or a
# netsh portproxy + firewall allow rule. Verification degrades gracefully if unset.

# --- Association rules (0..N) -----------------------------------------------
# Link external knowledge to repos. Rule TYPES are generic; the patterns/maps
# are yours.
[[rules]]
type = "branch_key"
pattern = '^[A-Z]+-\d+'           # extract an issue key from branch/commit names

[[rules]]
type = "key_map"
file = "~/.contextlake/key-map.toml"   # maps issue/space keys -> repo paths

[[rules]]
type = "link_scrape"
# scans README/docs for these URL patterns
patterns = ["https://*.atlassian.net/wiki/", "https://www.figma.com/"]
