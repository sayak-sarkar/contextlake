# Configuration files with sensitive data
.gitlab_sync.ini
.contextlake.ini
.contextlake.kb.toml

# Cache files
/tmp/*.txt
/tmp/*.json

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Packaging / build artifacts
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/

# Test / lint caches
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
coverage.xml

# IDE
# .vscode/
.idea/

# Local project planning notes (may reference private data — never published)
.notes/

# Local-only org-token denylist for the genericity guard (never published)
.genericity-denylist
