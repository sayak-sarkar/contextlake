# contextlake mirror configuration
# This is an example configuration file. Copy this file to .contextlake.ini
# and customize it with your specific settings.
#
# IMPORTANT: .contextlake.ini should be added to .gitignore to prevent
# accidentally committing sensitive configuration to version control.

[contextlake]
# Working directory where repositories will be cloned
# Supports ~ for home directory expansion
work_dir = ~/work

# Which platform to mirror from:
#   gitlab (default) | github | bitbucket | gitea | codeberg | forgejo
# platform = gitlab

# The group / org / workspace / owner to synchronize (all its repos are
# mirrored, preserving the namespace tree). `gitlab_group` works as an alias.
gitlab_group = your-gitlab-group
# group = your-org

# Authentication for enumeration + cloning: set the platform's token env var
# (GITLAB_TOKEN / GITHUB_TOKEN / BITBUCKET_TOKEN / GITEA_TOKEN) and contextlake
# calls the platform's REST API directly and clones with plain git, passing the
# credential via the child environment (never argv, never the clone URL).
#   - GitLab without a token falls back to the `glab` CLI (its own auth); the
#     token path is the robust one behind a slow/TLS-inspecting corporate proxy
#     (e.g. Zscaler), where glab's short dial timeout fails every request.
#   - Other platforms work tokenless for PUBLIC owners (rate-limited).
# Override the env-var name or API endpoint here if needed:
# token_env = GITHUB_TOKEN
# api_base = https://github.example.com/api/v3   # self-hosted / enterprise
# gitlab_token_env = GITLAB_TOKEN                # gitlab-specific alias
# gitlab_host = gitlab.com
# HTTP timeout (seconds) for the REST API enumeration:
# network_timeout = 30
# Per-process DNS resolver budget for child git operations, widened so slow
# corporate DNS (multi-second lookups) doesn't trip "i/o timeout" (root-free;
# skipped if you already export RES_OPTIONS):
# dns_timeout = 15
# dns_attempts = 3

# Cache directory for storing GitLab project information
# Default: /tmp
cache_dir = /tmp

# Cache file names (relative to cache_dir)
cache_file = gitlab_projects.txt
cache_json = gitlab_projects.json

# Timeout values (in seconds) for various operations
# Increase these if you have slow network or large repositories
clone_timeout = 300
fetch_timeout = 60
branch_timeout = 30
pull_timeout = 60

# Maximum number of parallel workers
# Higher values = faster but more resource intensive
# Reduce if you experience memory or network issues
max_workers = 8

# How repositories are cloned:
#   auto - `git` with the platform token when set; else `glab` (GitLab only,
#          uses its stored auth); else `git` over HTTPS
#   glab - always use `glab repo clone` (GitLab)
#   git  - always use `git clone` over HTTPS
clone_method = auto

# How the "most active" branch is chosen when switching branches:
#   commits - branch with the most commits (legacy behaviour)
#   recency - branch with the most recent commit
#   hybrid  - weighted blend of commit count and recency (recommended)
branch_strategy = hybrid

# Automatically remove corrupted/incomplete directories before cloning
# Set to false if you want to preserve existing directories even if they're not valid git repos
clean_corrupted = true

# Retry configuration for failed operations
# max_retries: Maximum number of retry attempts for failed operations
# backoff_initial: Initial backoff time in seconds (exponential backoff)
# backoff_max: Maximum backoff time in seconds
max_retries = 3
backoff_initial = 1
backoff_max = 30

# Adaptive parallelism configuration
# adaptive_workers: Enable dynamic worker pool adjustment based on error rate
# min_workers: Minimum number of workers (never go below this)
# error_threshold: Error rate threshold (0.0-1.0) to trigger worker reduction
adaptive_workers = true
min_workers = 2
error_threshold = 0.5

# Branch safety settings
#
# require_clean_workspace: the main guard. When true, a repo with a dirty
#   working tree (uncommitted/unstaged/untracked changes) is skipped by update
#   and branch-switch so local work is never clobbered. A CLEAN repo is acted
#   on regardless of which branch it is on -- the branch name alone never causes
#   a skip during update.
# protect_working_branches: applies ONLY to the `branches` command. When true,
#   a repo sitting on a branch outside `safe_branches` is left where it is
#   instead of being switched to its most-active branch (so you are never moved
#   off a feature branch you are working on). It does NOT affect `update`.
# auto_stash: when true, update stashes a dirty tree instead of skipping it.
require_clean_workspace = true
protect_working_branches = true
safe_branches = main,master,develop,development
auto_stash = false
